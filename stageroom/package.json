{
  "name": "stageroom",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd workers && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "deploy": "cd workers && npm run deploy"
  },
  "devDependencies": {
    "concurrently": "^9.2.0"
  }
}
