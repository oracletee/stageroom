# Cloudflare Stream
VITE_CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
VITE_STREAM_PLAYBACK_DOMAIN=your-custom-domain.com

# MediaMTX relay (WHIP)
VITE_RELAY_WHIP_URL=http://localhost:8889/whip/live

# Relay target server (sets Cloudflare RTMP target)
VITE_RELAY_TARGET_URL=http://localhost:9990/target

# LiveKit
VITE_LIVEKIT_URL=ws://localhost:7880
VITE_LIVEKIT_TOKEN=your-token-here

# STUN servers (comma-separated ICE servers)
VITE_STUN_SERVER_1=stun:stun.cloudflare.com:3478
VITE_STUN_SERVER_2=stun:stun.l.google.com:19302
VITE_STUN_SERVER_3=stun:stun1.l.google.com:19302
